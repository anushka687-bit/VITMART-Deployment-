APP_NAME=VITMart
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# React frontend origin (Admin Login page redirect target + CORS).
# Frontend (localhost:5173) and this backend must both be reached via the
# literal host "localhost" so cookies are same-site (default SameSite=lax
# is enough; no need for SameSite=None + Secure over plain HTTP).
# NOTE: deliberately NOT adding this origin to SANCTUM_STATEFUL_DOMAINS —
# the admin login hits /login, a plain "web" route unaffected by Sanctum's
# stateful-domains setting. Adding it there instead makes Sanctum's
# EnsureFrontendRequestsAreStateful middleware treat every /api/* request
# from this origin as CSRF-protected, which breaks the existing bearer-token
# customer OTP login/register flow (it was never designed to send a CSRF
# token).
FRONTEND_URL=http://localhost:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Admin account (used by DatabaseSeeder)
ADMIN_EMAIL=anushka.gupta2025@vitstudent.ac.in
ADMIN_PASSWORD=
